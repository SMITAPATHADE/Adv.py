</ul>

<h2>Our College:</h2>
<img src="{{ image }}" width="400">

</body>
</html>
""")

# Flask app
app = Flask(_name_)

@app.route('/')
def home():
    college_name = "ABC College"
    courses = ["BSc Computer Science", "BCA", "BCom", "BA", "MSc IT"]
    image_url = "https://via.placeholder.com/400"

    return render_template("index.html", 
                           college=college_name, 
                           courses=courses, 
                           image=image_url)

# Run app
app.run()